#environment, used especially for logging config
ENV=dev

#get them from the json file that you download after creating the service acc
PROJECT_ID=your_project_id
PRIVATE_KEY_ID=your_private_key_id
PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n
CLIENT_EMAIL=your_client_email
CLIENT_ID=your_client_id
CLIENT_X509_CERT_URL=your_client_x509_cert_url


#--------------UNCOMMENT ONLY ONE OF THESE-----------------------------------------
#--------JUST MAKE SURE THE PROVIDER IS SUPPORTED BY LANGCHAIN (see langchain docs)
#----------AND THE MODEL SUPPORTS TOOL CALLING-------------------------------

#groq (you can get a free api key from their website)
GROQ_API_KEY=your_groq_api_key
MODEL_PROVIDER=groq:qwen/qwen3-32b

#openai
# OPENAI_API_KEY=sk-...
# MODEL_PROVIDER=

#anthropic
# ANTHROPIC_API_KEY=anthropic-...
# MODEL_PROVIDER=

#google
# GOOGLE_API_KEY=AIza...
# MODEL_PROVIDER=

#for local serving using ollama
# OLLAMA_BASE_URL=http://host:11434 #make sure to expose the used port from docker
# MODEL_PROVIDER=ollama/llama3



#postgres checkpointer
POSTGRES_USER=sheet
POSTGRES_PASSWORD=password
POSTGRES_DB=sheet
